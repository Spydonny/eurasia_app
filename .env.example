# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000
# WebSocket base URL (notifications). Defaults to ws://localhost:8000 if unset.
VITE_WS_URL=ws://localhost:8000

# Firebase Cloud Messaging (web push) — optional; push is disabled if unset.
# Values come from Firebase console > Project settings > General > "Your apps" (Web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Web Push certificate key pair: Project settings > Cloud Messaging >
# "Web configuration" > Web Push certificates > Generate key pair (the public key).
VITE_FIREBASE_VAPID_KEY=

# Google Maps — powers the address picker on event create/edit. Optional; the
# picker falls back to plain City/Address text fields if unset. Needs the
# "Maps JavaScript API" + "Places API" enabled on the key.
VITE_GOOGLE_MAPS_API_KEY=
